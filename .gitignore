# ── eBPF build artifacts (tagger/bpf) ──
/tagger/bpf/vmlinux.h
/tagger/bpf/*.o
/tagger/bpf/tagger.skel.h

# ── C loader binary (tagger/c) ──
/tagger/c/tagger

